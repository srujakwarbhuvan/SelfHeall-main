# ── Core AI Engine ──────────────────────────────────────────
# Get your Gemini API key at: https://aistudio.google.com/apikey
# Multiple keys for rotation/failover (comma-separated)
GEMINI_API_KEYS=key1,key2,key3
# Single key (legacy/simple setup)
GEMINI_API_KEY=your_key_here

# ── Self-Healing Config ─────────────────────────────────────
# Minimum AI confidence required to apply a heal automaticallly
CONFIDENCE_THRESHOLD=0.8
# If true, AI won't patch files, only suggest fixes in terminal/dashboard
SAFE_MODE=true
# Process execution: skip patches and DB saves
SELFHEAL_DRY_RUN=false

# ── Server Configuration ─────────────────────────────────────
# Dashboard and API port (Render injects this as process.env.PORT)
PORT=3000
NODE_ENV=development

# ── Database Storage ─────────────────────────────────────────
# Path to SQLite database file
DB_PATH=./data/heals.db

# Managed PostgreSQL (Required if deploying to Render for long-term persistence)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://user:pass@render-host:5432/selfheal_db

# ── Firebase Cloud Sync ──────────────────────────────────────
# Optional: Set these if using the Firebase cloud persistence bridge
FIREBASE_API_KEY=your_apiKey
FIREBASE_AUTH_DOMAIN=your_authDomain
FIREBASE_PROJECT_ID=your_projectId
FIREBASE_STORAGE_BUCKET=your_storageBucket
FIREBASE_MESSAGING_SENDER_ID=your_messagingSenderId
FIREBASE_APP_ID=your_appId
FIREBASE_MEASUREMENT_ID=your_measurementId
